{
  "name": "ecommerce-api",
  "version": "1.0.0",
  "description": "E-Commerce API",
  "main": "app.js",
  "imports": {
    "#app": "./app.js",
    "#api/*": "./src/api/*.js",
    "#controllers/*": "./src/api/controllers/*.js",
    "#middleware/*": "./src/api/middleware/*.js",
    "#models/*": "./src/api/models/*.js",
    "#routes/*": "./src/api/routes/*.js",
    "#utils/*": "./src/api/utils/*.js"
  },
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js"
  },
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.2.2",
    "qs": "^6.15.0",
    "stripe": "^20.4.0",
    "validator": "^13.15.26"
  },
  "devDependencies": {
    "nodemon": "^3.0.0"
  }
}